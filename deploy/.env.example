# Territory Grounder — environment. Copy to deploy/.env and fill in.
# Secrets live HERE (or in a secret store), NEVER inline in code/config artifacts and NEVER committed
# (.env is gitignored). The Go config layer resolves secret REFERENCES (env:/file:) in memory only. [O] INV-13
#
# The values below are obvious "change-me" placeholders (allowlisted by the secret linter + gitleaks).

# --- Postgres bootstrap (container superuser, used only by init) ---
PG_SUPERUSER=postgres
PG_SUPERUSER_PASSWORD=change-me-superuser

# --- Two least-privilege DB roles (created by postgres-init/00-roles.sh) ---
# Set these; the DSNs below must embed the SAME passwords.
TG_MIGRATION_PASSWORD=change-me-migration
TG_RUNTIME_PASSWORD=change-me-runtime

# MIGRATION DSN — DDL role, used only at startup by the migrator.
TG_MIGRATION_DSN=postgres://tg_migration:change-me-migration@postgres:5432/grounder?sslmode=disable
# RUNTIME DSN — DML-only role, the app pool (subject to FORCE RLS).
TG_RUNTIME_DSN=postgres://tg_runtime:change-me-runtime@postgres:5432/grounder?sslmode=disable

# --- Temporal ---
TEMPORAL_PG_PASSWORD=change-me-temporal

# --- LiteLLM model-gateway ---
LITELLM_MASTER_KEY=change-me-litellm-master
# Provider keys for the fallback ladder (fill the ones you use; leave others blank):
KIMI_API_KEY=
ZAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# ==============================================================================
# Runner worker — OPERATIONAL CONFIG (config-not-code).
# Every knob below is CONFIG, never compiled in: no hostname, room, site, branch,
# service name, or DB path is baked into the binary. All are OPTIONAL — an unset
# knob disables that feature (an unconfigured estate source simply contributes no
# edges, and the gate fails closed on eligibility; it never fabricates topology).
# ==============================================================================

# --- External secret substrate (OpenBao) — spec/022 REQ-2200/REQ-2204, TG-156/TG-157 ---
# When TG_OPENBAO_ADDR is set, the process resolves its OWN SecretRefs (the *_REF vars below) as `bao:`
# references from OpenBao instead of plaintext env values — e.g. set TG_LITELLM_KEY_REF=bao:secret/data/tg/
# litellm#master_key after writing that value into OpenBao. Unset (default) ⇒ substrate OFF: env:/file: refs
# work exactly as before, and any bao: ref fails closed. The bootstrap token is the ONE secret that must stay
# an env:/file: ref (the substrate cannot authenticate itself from the substrate); make it a read-scoped token.
TG_OPENBAO_ADDR=                                    # e.g. https://openbao.example:8200 . Empty = substrate OFF.
TG_OPENBAO_TOKEN_REF=file:/secrets/openbao-token    # bootstrap token REF (env:/file: only), read-scoped
TG_OPENBAO_CA=                                      # optional path to the substrate's private-CA cert (shared with the credsource source)

# --- Runtime endpoints ---
TG_TEMPORAL_HOSTPORT=temporal:7233
TG_LITELLM_URL=http://litellm:4000
TG_LITELLM_KEY_REF=env:LITELLM_MASTER_KEY          # a secret REFERENCE (env:/file:/bao:), never the key itself
# Durable stores: point at the DML-only runtime DSN. Unset ⇒ in-memory (predictions/ledger do not survive restart).
TG_DB_DSN=${TG_RUNTIME_DSN}
TG_PUBLIC_ADDR=:8080                               # grounder public API listener (read-only surface + ingest front door)
TG_ADMIN_ADDR=:8443                                # grounder elevated admin listener (mTLS)

# --- Estate topology sources (the causal graph the prediction gate reasons over) ---
# Live sources (highest trust); each is added only when its URL is set.
TG_NETBOX_URL=                                     # e.g. https://netbox.example  → VM→host runs_on edges
TG_NETBOX_TOKEN_REF=env:NETBOX_TOKEN
TG_NETBOX_CASCADE_ALERT=HostDown
TG_PVE_URL=                                        # e.g. https://pve01:8006      → guest→node runs_on edges (0.95, source of truth)
TG_PVE_TOKEN_REF=env:PVE_API_TOKEN
TG_PVE_CASCADE_ALERT=HostDown
# Multiple sites are supported (';'-separated); each is discriminated by the payload's `site` field on
# push. e.g. NL|https://dc1nms01/api/v0|env:LIBRENMS_NL_TOKEN;GR|https://dc2nms01/api/v0|env:LIBRENMS_GR_TOKEN
TG_LIBRENMS_DEPLOYMENTS=                           # 'site|https://lnms|env:LNMS_TOKEN;site2|...' → topology edges + ingest (front door accepts POST /v1/ingest/librenms per site)
TG_LIBRENMS_CASCADE_ALERT=DeviceDown
# Alert intake is PUSH by default (LibreNMS transports POST /v1/ingest/librenms, per-source bearer — see
# TG_LIBRENMS_INGEST_TOKEN below). This active-alert PULL is a deprecated opt-in FALLBACK for an
# air-gapped/transport-less deployment: empty (the default) disables it; set a duration to re-enable.
TG_LIBRENMS_ALERT_POLL_INTERVAL=                   # e.g. 60s — worker polls each deployment's active alerts (state=1) and mints a triage per new alert; empty/0 disables (push is primary)
TG_LIBRENMS_INSECURE=                              # set truthy to skip TLS verify for the estate pollers (LibreNMS self-signed cert); read pollers only

# --- Host-read identities (syslog-ng log reads, host diagnostics, journal/sudo attribution) ---
# TG NEVER creates accounts, groups, or keys on your hosts — it is a CONSUMER of an SSH identity that YOU
# provide. Each row names the (sshuser, keyref) TG should connect AS; the choice is entirely yours:
#   • SIMPLEST (out-of-box): your existing admin identity — e.g. root + the key TG already holds:
#       SITE|loghost.example|root|file:/secrets/one_key|/mnt/logs/syslog-ng
#   • LEAST-PRIVILEGE (opt-in): a read-only user YOU provision on the hosts + a dedicated key:
#       SITE|loghost.example|log-ro|file:/secrets/your-read-key|/mnt/logs/syslog-ng
#     (root reads everything; a least-priv user needs read on the log path, and — for the journal readers
#      below — membership in the systemd-journal group. Provisioning that user/key is YOUR job, not TG's.)
# SECURITY: root|<admin-key> puts a powerful key on the read path (a worker compromise ⇒ admin) — prefer a
# dedicated read identity if your threat model warrants it. The keyref is always file:/env: (material NEVER
# committed); with the compose stack place private keys under deploy/secrets/ (gitignored, mounts ro at /secrets).
#
# syslog-ng servers: 'site|sshhost|sshuser|keyref|basepath[|prefix]' rows, ';'-separated.
TG_SYSLOGNG_DEPLOYMENTS=
# Host diagnostics (df/du/journalctl during triage): 'site|hostglob|sshuser|keyref' rows, ';'-separated.
TG_HOSTDIAG_DEPLOYMENTS=
# Journal/sudo actor-attribution (WHO ran a privileged action): 'site|hostglob' rows — the SSH identity is
# resolved from TG_HOSTDIAG_DEPLOYMENTS above, so that identity must have journal read access (root, or a
# user in the systemd-journal group).
TG_JOURNAL_DEPLOYMENTS=
# MANDATORY alongside ALL of the above: the OpenSSH known_hosts file pinning each host's key (one file covers
# every host). Collect it ONCE with ssh-keyscan on a trusted path, verify fingerprints out of band, place it
# at deploy/secrets/known_hosts. The native in-process SSH client fails closed without it; an unknown or
# changed host key refuses the read (no bypass exists).
TG_SYSLOGNG_KNOWN_HOSTS=                            # e.g. /secrets/known_hosts
# Attribution readers for automation + CMDB domains (spec/023): explicit opt-in (empty = dormant). Set truthy
# to arm; they reuse the already-configured AWX (TG_AWX_ADDR/TG_AWX_TOKEN_REF) and NetBox
# (TG_NETBOX_URL/TG_NETBOX_TOKEN_REF) read credentials. Arming adds WHO-signal to triage (transparency-gated).
TG_AWX_ACTOREVIDENCE=                               # e.g. on — attribute automation-driven changes (AWX job launcher)
TG_NETBOX_ACTOREVIDENCE=                            # e.g. on — attribute CMDB edits (NetBox changelog user)
# GitOps MR-history attribution (who merged a deploy-manifest change). Opt-in; needs the GitLab URL + project
# + a READ-ONLY project token (reporter/read_repository — NEVER the admin/deploy token). Branch/prefix optional.
TG_GITOPSMR_ACTOREVIDENCE=                          # e.g. on — attribute declarative-deploy changes (GitLab merged_by)
TG_GITLAB_URL=                                      # e.g. https://gitlab.example (REST API at /api/v4)
TG_GITLAB_PROJECT=                                  # project id or URL-encoded path, e.g. 48 or group%2Fproject
TG_GITLAB_RO_TOKEN_REF=                             # e.g. bao:secret/data/tg/gitlab#ro_token (read-only project token)
TG_GITOPSMR_BRANCH=                                 # deploy branch, default main
TG_GITOPSMR_MANIFEST_PREFIX=                        # manifest path prefix, default deploy/
TG_HOSTDIAG_KNOWN_HOSTS=                            # e.g. /secrets/known_hosts
TG_JOURNAL_KNOWN_HOSTS=                             # e.g. /secrets/known_hosts
# Operator-maintained edge files (fill gaps live sources miss; always out-ranked by a live source).
TG_ESTATE_DECLARED_FILE=                           # JSON edges at SourceDeclared 0.85
TG_ESTATE_TUNNEL_FILE=                             # JSON tunnels at SourceTunnel 1.0 (cross-site routes_via)
TG_ESTATE_LEARNED_FILE=                            # JSON co-occurrence history to seed the learned tier (<=0.75)
# Re-read the live topology (and fold in learned edges) on this interval WITHOUT a restart. Empty = off.
TG_ESTATE_REFRESH_INTERVAL=                        # e.g. 15m

# --- Classifier bands (config-not-code safety tiers) ---
TG_CRITICALITY_TIER_HOSTS=                         # comma/space list of P0 hosts → ceiling at AUTO_NOTICE, never silent AUTO
TG_SELF_PROTECTED_SERVICES=                        # comma/space list of the platform's OWN services → a restart of them is polled
TG_BLAST_RADIUS_WIDE_THRESHOLD=8                   # predicted-cascade width at/above which an action ceilings at AUTO_NOTICE

# --- Image source (GitOps deploy) ---
# In production the AWX deploy playbook sets these so `docker compose pull` fetches the CI-built images from
# the GitLab Container Registry by tag; locally, leave them unset and `docker compose up --build` builds from
# source. TG_TAG is the deployed commit (short SHA), or "latest".
TG_GROUNDER_IMAGE=registry-github.com/territory-grounder/grounder/grounder
TG_WORKER_IMAGE=registry-github.com/territory-grounder/grounder/worker
TG_CONSOLE_IMAGE=registry-github.com/territory-grounder/grounder/console
TG_TAG=latest

# --- Retrieval plane (RAG precedent for the agent) ---
# The corpus is a UNION of two files: the worker WRITES only the MAINTAINED corpus (untracked on the
# box, so it survives deploys); the SEED is the tracked, deploy-synced bootstrap (TG-125,
# deploy/knowledge/corpus.seed.json) that is overwritten on every deploy and must be treated read-only.
TG_KNOWLEDGE_FILE=/knowledge/corpus.maintained.json # worker-maintained corpus (novelty writeback + lessons
                                                   # merge land HERE). Untracked ⇒ deploy-persistent.
                                                   # Blank = honestly empty (all shapes ood-novel).
TG_KNOWLEDGE_SEED_FILE=/knowledge/corpus.seed.json  # read-only bootstrap precedents, unioned under the
                                                   # maintained corpus on every load. Deploy re-syncs it;
                                                   # NEVER point TG_KNOWLEDGE_FILE at it (runtime rows
                                                   # would be wiped by the next deploy).
TG_KNOWLEDGE_REFRESH_INTERVAL=                     # reload the corpus on this interval without a restart. Empty = off.
# The lessons persistence hop — closes the learn→retrieve loop. A resolved-incident feed (JSON array of
# {"external_ref","host","alert_rule","site","summary","action","verdict","confirmed_clear","tags"}) is
# distilled to its CONFIRMED-CLEAN subset (verdict=match AND confirmed_clear=true) and merged into
# TG_KNOWLEDGE_FILE above — so a verified resolution becomes citable precedent and a deviation/partial/
# unconfirmed outcome never poisons the corpus. Requires TG_KNOWLEDGE_FILE. Folded in at boot + on interval.
TG_LESSONS_SOURCE_FILE=                            # resolved-incident history to distill into the corpus. Empty = off.
TG_LESSONS_REFRESH_INTERVAL=                       # re-fold the feed on this interval without a restart. Empty = boot-only.
# The SEMANTIC channel (pgvector, migration 0013): precedent embeddings are RRF-fused with the lexical
# ranking; a paraphrased incident surfaces the precedent token overlap misses. Strictly additive and
# fail-open — empty TG_EMBED_MODEL, no DB, or an embedding outage ⇒ exactly the lexical behavior above.
# Requires TG_KNOWLEDGE_FILE + TG_DB_DSN. The model is served by the LiteLLM gateway's /v1/embeddings
# (add an embedding entry to litellm-config.yaml — see the commented example there).
TG_EMBED_MODEL=                                    # embedding model name at the gateway (e.g. embed-nomic). Empty = semantic retrieval OFF.
TG_EMBED_DIM=                                      # embedding dimension; must equal the migrated column (768). Default 768; boot refuses a mismatch.
TG_EMBED_MIN_SIMILARITY=                           # cosine floor below which a semantic match never enters the seed. Default 0.5.
TG_EMBED_BACKFILL_INTERVAL=                        # embed-unembedded sweep interval. Default 10m; 0 = sweep off (corpus writes still embed).
TG_EMBED_BACKFILL_BATCH=                           # max rows embedded per sweep pass. Default 64.

# --- Tier-1 suppression (config-not-code; the Runner's FIRST gate — a suppressed alert spends no session) ---
# JSON [{"scope":"host-or-rule-or-empty","start":"RFC3339","end":"RFC3339","reason":"..."}]. A declared
# maintenance/chaos window suppresses even a critical alert (the operator declared it coming).
TG_SUPPRESSION_FREEZE_FILE=
# JSON [{"host":"glob","rule":"glob","reason":"..."}] operator suppress-rules (path.Match; a catch-all */*
# is refused, and critical/unknown severity is never suppressed by a rule). Both empty ⇒ every alert triaged.
TG_SUPPRESSION_RULES_FILE=
# Dedup window: a re-fire of the same (host, alert_rule) within this window is deduped (no second session).
# Best-effort, per-worker, fail-open. Empty/0 = dedup off.
TG_SUPPRESSION_DEDUP_WINDOW=                       # e.g. 10m
# JSON [{"alert_rule":"...","estate":"...","confidence":0.8}] operator-declared known-transient patterns. A
# pattern suppresses only at confidence >= 0.7 AND with a transient keyword (flap/blip/recover/…) in the rule
# — a standing fault like DiskFull is never auto-suppressed. Empty ⇒ no known-pattern suppression.
TG_SUPPRESSION_PATTERNS_FILE=
# JSON [{"host":"...","cron":"0 3 * * *","timezone":"Europe/Athens","valid_from":"RFC3339","valid_until":"RFC3339"}]
# operator-declared recurring reboot schedules. A reboot-class alert on the host inside the cron window (±
# tolerance below) is suppressed; a non-reboot alert on the same host is investigated. Empty ⇒ none.
TG_SUPPRESSION_SCHEDULES_FILE=
TG_SUPPRESSION_REBOOT_PRE_BUFFER=                  # how long BEFORE a scheduled reboot fire an alert still matches (default 5m)
TG_SUPPRESSION_REBOOT_WINDOW=                      # how long AFTER  a scheduled reboot fire an alert still matches (default 10m)
# JSON [{"host":"child-or-*","rule":"child-rule-or-*","site":"...","valid_from":"RFC3339","valid_until":"RFC3339"}]
# blast-radius fold policies: a matching CHILD alert is folded (posted as a notice, no session) while valid.
# A catch-all (host=* rule=*) is refused. Empty ⇒ no fold suppression.
TG_SUPPRESSION_FOLDS_FILE=

# ============================================================================
# Connector fleet (spec/008) — config-not-code capability declaration.
# The worker registers a connector into the runtime module registry ONLY where
# its endpoint is declared here (INV-17: an unconfigured connector is not a
# capability). Every credential is a SECRET REFERENCE (env:NAME or file:/path),
# never a literal secret (INV-13). Leave a family's URL empty to omit it.
# ============================================================================

# --- Issue trackers (incident filing + state transitions) ---
TG_YOUTRACK_URL=                                   # e.g. https://youtrack.example
TG_YOUTRACK_TOKEN_REF=env:YOUTRACK_TOKEN
# The project's YouTrack State-bundle value names + the State field name. The DEFAULT bundle has NO "Resolved"
# value (its terminal is "Fixed"/"Verified"), so a real project must set the resolved value to one that EXISTS
# or every close-out no-ops. Empty ⇒ reference default (in-progress="In Progress", resolved="Resolved",
# open="Open", field="State").
TG_YOUTRACK_STATE_INPROGRESS=                      # State value name for In Progress
TG_YOUTRACK_STATE_RESOLVED=                        # State value name for Resolved (e.g. Fixed on a default bundle)
TG_YOUTRACK_STATE_OPEN=                            # State value name for Open
TG_YOUTRACK_STATE_FIELD=                           # the custom-field name holding the state (default "State")
TG_JIRA_URL=                                       # e.g. https://jira.example
TG_JIRA_EMAIL=                                     # the API account email
TG_JIRA_TOKEN_REF=env:JIRA_TOKEN
# The deployment's own Jira workflow transition ids (GET /rest/api/2/issue/{key}/transitions to discover
# them). A real workflow rarely uses the reference ids, and POSTing an id the workflow lacks 404s every
# close-out. Empty ⇒ the reference default (in-progress=21, resolved=31, open=11).
TG_JIRA_TRANSITION_INPROGRESS=                     # transition id that moves an issue to In Progress
TG_JIRA_TRANSITION_RESOLVED=                       # transition id that moves an issue to Resolved/Done
TG_JIRA_TRANSITION_OPEN=                           # transition id that reopens an issue
TG_GITHUB_URL=                                     # e.g. https://api.github.com
TG_GITHUB_OWNER=                                   # repo owner/org
TG_GITHUB_REPO=                                    # repo name
TG_GITHUB_TOKEN_REF=env:GITHUB_TOKEN
TG_SERVICENOW_URL=                                 # e.g. https://acme.service-now.com
TG_SERVICENOW_USER=                                # the API username
TG_SERVICENOW_TOKEN_REF=env:SERVICENOW_TOKEN
# The instance's incident.state numeric codes. incident.state is a per-instance choice list; a customized
# instance that doesn't use the out-of-box values will mis-set/fail every close-out. Empty ⇒ ITSM default
# (in-progress=2, resolved=6, open=1); the "Closed" code 7 always reads back as resolved.
TG_SERVICENOW_STATE_INPROGRESS=                    # incident.state code for In Progress
TG_SERVICENOW_STATE_RESOLVED=                      # incident.state code for Resolved
TG_SERVICENOW_STATE_OPEN=                          # incident.state code for Open/New

# --- Notifiers (approval-poll delivery + vote binding). Each APPROVERS list is
#     the human-authorization roster for that channel (INV-12): a vote binds a
#     decision only from a listed sender. Comma/space separated.
#     DESTINATION: an approval routes to a channel/room named "#<project>-approvals"
#     (from the decision-id prefix). Set a DEFAULT to send every approval to one
#     place (the common case), or a ROOMS/CHANNELS map ("#tg-approvals=<real>,...")
#     to route per project. Without one, the computed name is used verbatim — which
#     is NOT a valid Matrix alias and rarely an existing Slack channel, so the poll
#     is undeliverable. The map/default value is the REAL destination: a Matrix room
#     id (!abc:server) or alias (#room:server); a Slack channel id (C0123…) or #name. ---
TG_MATRIX_HOMESERVER=                              # e.g. https://matrix.example
TG_MATRIX_TOKEN_REF=env:MATRIX_TOKEN
TG_MATRIX_APPROVERS=                               # e.g. @oncall:example, @lead:example
TG_MATRIX_DEFAULT_ROOM=                            # send every approval here, e.g. !abcdef:example or #ops:example
TG_MATRIX_ROOMS=                                   # per-project: "#tg-approvals=!room:example, #ops-approvals=#ops:example"
TG_SLACK_URL=                                      # e.g. https://slack.com/api
TG_SLACK_TOKEN_REF=env:SLACK_TOKEN
TG_SLACK_APPROVERS=                                # Slack user ids
TG_SLACK_DEFAULT_CHANNEL=                          # send every approval here, e.g. C0123456 (a channel id the bot joined)
TG_SLACK_CHANNELS=                                 # per-project: "#tg-approvals=C0123456, #ops-approvals=C0987654"
TG_TEAMS_URL=                                      # Teams bot/webhook base
TG_TEAMS_CONVERSATION=                             # conversation/channel id
TG_TEAMS_TOKEN_REF=env:TEAMS_TOKEN
TG_TEAMS_APPROVERS=
TG_EMAIL_SMTP=                                     # host:port of the SMTP relay
TG_EMAIL_FROM=                                     # From: address
TG_EMAIL_TO=                                       # comma/space list of recipients
TG_EMAIL_APPROVERS=                                # senders whose replies count as votes
# SMTP PLAIN auth. Most real relays require it; without a username the no-auth path is used (and an
# auth-requiring relay refuses every send). net/smtp refuses PLAIN credentials over an unencrypted,
# non-localhost link, so this only transmits over a STARTTLS-upgraded connection. Empty user ⇒ no auth.
TG_EMAIL_SMTP_USER=                                # SMTP AUTH username
TG_EMAIL_SMTP_TOKEN_REF=env:EMAIL_SMTP_PASSWORD    # secret ref for the SMTP password (resolved at send time)
TG_TWILIO_URL=                                     # Twilio API base
TG_TWILIO_SID=                                     # account SID
TG_TWILIO_FROM=                                    # sending number
TG_TWILIO_TO=                                      # paging number
TG_TWILIO_TOKEN_REF=env:TWILIO_TOKEN
TG_MATTERMOST_URL=                                 # e.g. https://mm.example
TG_MATTERMOST_TOKEN_REF=env:MATTERMOST_TOKEN
TG_MATTERMOST_APPROVERS=
TG_MATTERMOST_CHANNELS=                            # REQUIRED to deliver: "tg-approvals=<26-char channel id>, ..." (create-post 400s on a name)

# --- CMDB (authoritative entity reconciliation). NetBox reuses the estate's
#     TG_NETBOX_URL / TG_NETBOX_TOKEN_REF above. PVE is an estate source, not a
#     CMDB resolver, so it is not a CMDB capability. ---

# --- Observability exporters (endpoint-driven; Prometheus + Grafana declare
#     with no config and need nothing here). ---
TG_OPENOBSERVE_URL=                                # OTLP/ingest endpoint
TG_OPENOBSERVE_TOKEN_REF=env:OPENOBSERVE_TOKEN
TG_LANGFUSE_URL=                                   # Langfuse endpoint
TG_LANGFUSE_PUBLIC_REF=env:LANGFUSE_PUBLIC_KEY
TG_LANGFUSE_SECRET_REF=env:LANGFUSE_SECRET_KEY
TG_HEALTHCHECKS_URL=                               # Healthchecks.io base
TG_HEALTHCHECKS_CHECK_REF=env:HEALTHCHECKS_UUID
# Worker self-telemetry: export liveness + declared-capability gauges to the enabled exporters on this
# interval WITHOUT a restart. Empty = off; no configured exporter = no loop.
TG_OBSERVABILITY_EXPORT_INTERVAL=                  # e.g. 30s

# --- Fleet integrity: pin the expected live capability set (surface/source
#     slugs, e.g. "model/zai tracker/youtrack notifier/matrix"). If set, the
#     worker REFUSES TO START when the live fleet diverges — an unexpected
#     capability (a config slip / supply-chain surprise) or a missing declared
#     one (a connector that failed to register). Empty = opt out (log only). ---
TG_EXPECTED_CAPABILITIES=

# --- Browser operator session (spec/006 REQ-508): read-only console login ---
# Generate: TG_SESSION_KEY=$(openssl rand -hex 32); TG_OPERATOR_TOKEN=$(openssl rand -hex 24)
# Leave unset to keep the browser path disabled (machine auth is unaffected either way).
TG_SESSION_KEY=
TG_OPERATOR_NAME=operator
TG_OPERATOR_TOKEN=

# --- Alertmanager push ingest (spec/006 AuthIngestPush): per-source static bearer ---
# Referenced by the sources row (ingest_token_ref = env:TG_AM_INGEST_TOKEN); the same value is what
# Alertmanager presents via its credentials_file. Generate: openssl rand -hex 32. Leave unset if the
# Alertmanager source instead authenticates via HMAC/mTLS (a machine credential always wins over bearer).
TG_AM_INGEST_TOKEN=

# --- LibreNMS push ingest (spec/006 AuthIngestPush): per-source static bearer ---
# Push is the PRIMARY LibreNMS intake: the LibreNMS transports (NL dc1nms01, GR dc2nms01) POST
# each alert to /v1/ingest/librenms and present THIS value as the bearer. When TG_LIBRENMS_DEPLOYMENTS is
# declared AND this resolves non-empty, the grounder boot idempotently provisions the `librenms` sources
# row (ingest_token_ref = TG_LIBRENMS_INGEST_TOKEN_REF, default env:TG_LIBRENMS_INGEST_TOKEN) — no hand-run
# SQL. The secret VALUE lives ONLY here in .env, never in-repo. Generate: openssl rand -hex 32. Leave unset
# to skip provisioning (LibreNMS pushes then 401 fail-closed until a credential exists).
TG_LIBRENMS_INGEST_TOKEN_REF=env:TG_LIBRENMS_INGEST_TOKEN
TG_LIBRENMS_INGEST_TOKEN=

# --- Worker durability + estate topology sources (read-only; mutation stays OFF) ---
# TG_DB_DSN defaults to TG_RUNTIME_DSN (durable stores + estate publish). Override only if the worker
# should use a different DB. Estate sources build the causal graph served at /v1/estate:
# TG_NETBOX_URL=https://netbox.internal/api
# NETBOX_TOKEN=<netbox api token>            # referenced by TG_NETBOX_TOKEN_REF=env:NETBOX_TOKEN
# TG_PVE_URL=https://pve.internal:8006/api2/json
# PVE_TOKEN=<proxmox api token>              # referenced by TG_PVE_TOKEN_REF=env:PVE_TOKEN
# TG_LIBRENMS_DEPLOYMENTS=dc1|https://librenms.internal/api/v0|env:LIBRENMS_TOKEN
# LIBRENMS_TOKEN=<librenms api token>
# TG_ESTATE_REFRESH_INTERVAL=5m

# --- Skill-store flywheel (worker; spec/012). Generation + trial + offline gate knobs. Each is OPTIONAL:
# unset ⇒ the in-code default shown. These were previously not forwarded by compose, so the flywheel ran
# on defaults in prod regardless of what an operator set here. Mutation stays OFF. ---
# TG_SKILL_GEN_THRESHOLD=3.5             # judged-dimension mean below this triggers a candidate generation
# TG_SKILL_GEN_MIN_SAMPLES=5            # min judged samples before generation can fire (evidence gate)
# TG_SKILL_GEN_WINDOW=336h             # rolling window for the generation trigger (default 14d)
# TG_SKILL_GEN_MAX_SKILLS=1            # TG-63 cap: per run, draft for at most this many WORST-regressed skills (a global-low dimension must not flood every skill; cron drains the backlog worst-first)
# TG_SKILL_OFFLINE_MAX_ADMIT_PER_RUN=3 # TG-63 cap: per run, offline-admit at most this many OLDEST drafts (keeps admit-all within the activity budget; cron drains the backlog)
# TG_SKILL_TRIAL_MIN_SAMPLES=30       # min samples PER ARM before a trial can conclude
# TG_SKILL_TRIAL_MIN_LIFT=0.2        # min lift the challenger must show over the champion
# TG_SKILL_TRIAL_P=0.05             # significance threshold for the trial verdict
# TG_SKILL_TRIAL_DURATION=336h     # max trial duration (default 14d). On a data-starved estate you may raise
#                                  # this (e.g. 1200h/50d) so a trial can accumulate enough per-arm samples to
#                                  # conclude — but see FILL_HORIZON: a long duration alone would defeat the
#                                  # anti-starvation dimension steering, so the flywheel bounds steering separately.
# TG_SKILL_TRIAL_FILL_HORIZON=336h # STEERING horizon (default 14d): the flywheel targets a regressed dimension a
#                                  # trial can PRACTICALLY complete on within THIS window, NOT the full
#                                  # TRIAL_DURATION. Keeps a long TRIAL_DURATION from steering generation onto a
#                                  # proposer-only-sparse dimension that only ever timeout-aborts. Usually leave unset.
# TG_SKILL_TRIAL_MAX_CANDIDATES=1  # TG-65 cap: a trial arms control + at most this many top-by-offline-delta admitted candidates (keeps the arm count — and StartTrial's traffic bar — bounded so a trial can start at bootstrap traffic; a skill trials in waves)
# TG_SKILL_OFFLINE_DISCOVERY_LIMIT=6      # offline replay: max incidents pulled for the pre-promotion gate
# TG_SKILL_OFFLINE_REGRESSION_SLACK=0.25 # offline replay: allowed regression slack vs the production body
# TG_SKILL_OFFLINE_MIN_INCIDENTS=3      # offline replay fails CLOSED below this many comparable incidents

# --- Falsifiability scoring loop (worker). SCORE_INTERVAL gates the loop; its 5m default keeps scoring ON,
# so compose forwards it explicitly (an empty value would DISABLE scoring). WINDOW/BATCH default 10m/200. ---
# TG_FALSIFIABILITY_SCORE_INTERVAL=5m
# TG_FALSIFIABILITY_WINDOW=10m
# TG_FALSIFIABILITY_BATCH=200

# --- Actuation (SSH) target for the safe read-only actuator. Inert while mutation is OFF: the interceptor
# refuses before anything executes, so these never drive a change today. ---
# TG_ACTUATION_SSH_HOST=               # the single canary target host (empty ⇒ read-only reference leaf)
# TG_ACTUATION_SSH_IDENTITY=           # the scoped SSH USERNAME on the target (e.g. tg-actuator), never a key
# TG_ACTUATION_SSH_KNOWN_HOSTS=        # path to an OpenSSH known_hosts file carrying the target's host key
# TG_ACTUATION_SSH_KEY=                # key REFERENCE for the scoped identity (env:NAME / file:/run/secrets/…)
# TG_ACTUATION_ALLOWED_UNITS=          # allowlist of reversible unit ops (registry-gated)
# TG_ACTUATION_SSH_PER_TARGET=         # 1 ⇒ FLEET actuation (spec/017 REQ-1717): each action's leaf binds to
#                                      # its OWN target host (not the single HOST above), using the identity+key
#                                      # here over KNOWN_HOSTS. Empty/0 ⇒ single-host canary (default). Dormant
#                                      # until the mode actuates AND ALLOWED_UNITS is non-empty; per-target host
#                                      # must be in KNOWN_HOSTS; the actuation identity MUST differ from any read
#                                      # identity (the credential plane-split). CONSEQUENTIAL — arm deliberately.
# TG_ACTUATION_ALLOWED_CONTAINERS=     # allowlist of docker containers for restart-container (registry-gated).
#                                      # Allowlist ONLY non-stateful containers: the stateful-workload floor
#                                      # matches by NAME (postgres/redis/…), so a stateful app in a
#                                      # differently-named container is not auto-floored — your allowlist is
#                                      # the primary safety control.
# TG_INITIAL_MODE=                     # deploy-time INITIAL autonomy mode, seeded on a FRESH deploy ONLY
#                                      # (absent-only; never overrides an existing mode). shadow (default) |
#                                      # hitl | semi-auto | full-auto. Fail-closed: unset/invalid ⇒ Shadow;
#                                      # an actuating value still needs the green preflight + is ledger-audited.

# --- Grounder session lifetime + credential REFERENCE handles. The *_REF values default to the env:NAME
# targets already set above (TG_SESSION_KEY / TG_OPERATOR_TOKEN / TG_ADMIN_TOKEN / TG_SEAL_KEY), so you
# normally leave them unset; override only to point a credential at a different ref (e.g. file:/…). ---
# TG_SESSION_TTL=12h                    # browser operator session lifetime (default 12h)
# TG_SESSION_KEY_REF=env:TG_SESSION_KEY
# TG_OPERATOR_TOKEN_REF=env:TG_OPERATOR_TOKEN
# TG_ADMIN_TOKEN_REF=env:TG_ADMIN_TOKEN
# TG_SEAL_KEY_REF=env:TG_SEAL_KEY
# Sealed-secret master key via OpenBao Transit (spec/022 REQ-2201) — the worker holds NO master key: the DEK
# wrap/unwrap runs INSIDE OpenBao. Set TG_SEAL_TRANSIT_KEY to a Transit key name to enable (else the in-process
# TG_SEAL_KEY_REF above is used). Reuses the credential-delivery OpenBao endpoint by default (ADDR/TOKEN_REF/CA);
# give it a DISJOINT token (encrypt/decrypt-only on that key) to split the seal plane from the process-secret plane.
# TG_SEAL_TRANSIT_KEY=tg-seal
# TG_SEAL_TRANSIT_ADDR=                    # defaults to TG_OPENBAO_ADDR
# TG_SEAL_TRANSIT_TOKEN_REF=               # defaults to TG_OPENBAO_TOKEN_REF; use a tg-seal-ro token to split planes
# TG_SEAL_TRANSIT_MOUNT=transit            # OpenBao transit mount path

# --- Referenced secret VALUES for the worker notifier/ITSM + observability sinks. Each is the secret the
# matching TG_*_TOKEN_REF (documented above) points at via env:NAME; compose forwards these so the ref
# resolves in-container. Values live ONLY here in .env, never in-repo. Set the ones you wire up. ---
# YOUTRACK_TOKEN=
# JIRA_TOKEN=
# GITHUB_TOKEN=
# SERVICENOW_TOKEN=
# MATRIX_TOKEN=
# SLACK_TOKEN=
# TEAMS_TOKEN=
# MATTERMOST_TOKEN=
# TWILIO_TOKEN=
# EMAIL_SMTP_PASSWORD=
# OPENOBSERVE_TOKEN=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# HEALTHCHECKS_UUID=
