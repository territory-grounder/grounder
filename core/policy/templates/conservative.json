{
  "default": {
    "band_mode": "respect",
    "rate_limit": 30
  },
  "rules": [
    { "id": "deny-rm-rf-root",            "verdict": "deny", "match": { "argv_pattern": "rm -rf /" } },
    { "id": "deny-rm-rf-home-tilde",      "verdict": "deny", "match": { "argv_pattern": "rm -rf ~" } },
    { "id": "deny-rm-rf-home",            "verdict": "deny", "match": { "argv_pattern": "rm -rf /home" } },
    { "id": "deny-rm-rf-etc",             "verdict": "deny", "match": { "argv_pattern": "rm -rf /etc" } },
    { "id": "deny-rm-rf-var",             "verdict": "deny", "match": { "argv_pattern": "rm -rf /var" } },
    { "id": "deny-reboot",                "verdict": "deny", "match": { "argv_pattern": "reboot" } },
    { "id": "deny-shutdown",              "verdict": "deny", "match": { "argv_pattern": "shutdown" } },
    { "id": "deny-init-0",                "verdict": "deny", "match": { "argv_pattern": "init 0" } },
    { "id": "deny-init-6",                "verdict": "deny", "match": { "argv_pattern": "init 6" } },
    { "id": "deny-halt",                  "verdict": "deny", "match": { "argv_pattern": "halt" } },
    { "id": "deny-poweroff",              "verdict": "deny", "match": { "argv_pattern": "poweroff" } },
    { "id": "deny-mkfs",                  "verdict": "deny", "match": { "argv_pattern": "mkfs" } },
    { "id": "deny-dd-if-zero",            "verdict": "deny", "match": { "argv_pattern": "dd if=/dev/zero" } },
    { "id": "deny-dd-of-sd",              "verdict": "deny", "match": { "argv_pattern": "dd of=/dev/sd" } },
    { "id": "deny-redirect-block-dev",    "verdict": "deny", "match": { "argv_pattern": "> /dev/sd" } },
    { "id": "deny-kubectl-del-ns",        "verdict": "deny", "match": { "argv_pattern": "kubectl delete namespace" } },
    { "id": "deny-kubectl-del-all",       "verdict": "deny", "match": { "argv_pattern": "kubectl delete --all" } },
    { "id": "deny-kubectl-del-A",         "verdict": "deny", "match": { "argv_pattern": "kubectl delete -A" } },
    { "id": "deny-iptables-flush",        "verdict": "deny", "match": { "argv_pattern": "iptables -F" } },
    { "id": "deny-iptables-delete-chain", "verdict": "deny", "match": { "argv_pattern": "iptables -X" } },
    { "id": "deny-systemctl-stop-n8n",    "verdict": "deny", "match": { "argv_pattern": "systemctl stop n8n" } },
    { "id": "deny-systemctl-disable-n8n", "verdict": "deny", "match": { "argv_pattern": "systemctl disable n8n" } },
    { "id": "deny-systemctl-stop-oclaw",  "verdict": "deny", "match": { "argv_pattern": "systemctl stop openclaw" } },
    { "id": "deny-pkill-9",               "verdict": "deny", "match": { "argv_pattern": "pkill -9" } },
    { "id": "deny-kill-9-init",           "verdict": "deny", "match": { "argv_pattern": "kill -9 1" } },
    { "id": "deny-chmod-777-root",        "verdict": "deny", "match": { "argv_pattern": "chmod -R 777 /" } },
    { "id": "deny-chown-recursive",       "verdict": "deny", "match": { "argv_pattern": "chown -R" } },
    { "id": "deny-passwd",                "verdict": "deny", "match": { "argv_pattern": "passwd" } },
    { "id": "deny-useradd",               "verdict": "deny", "match": { "argv_pattern": "useradd" } },
    { "id": "deny-userdel",               "verdict": "deny", "match": { "argv_pattern": "userdel" } },
    { "id": "deny-visudo",                "verdict": "deny", "match": { "argv_pattern": "visudo" } },
    { "id": "deny-crontab-remove",        "verdict": "deny", "match": { "argv_pattern": "crontab -r" } },
    { "id": "deny-reverse-shell-bash-i",  "verdict": "deny", "match": { "argv_pattern": "bash -i" } },
    { "id": "deny-reverse-shell-devtcp",  "verdict": "deny", "match": { "argv_pattern": "/dev/tcp" } },
    { "id": "deny-reverse-shell-nc-e",    "verdict": "deny", "match": { "argv_pattern": "nc -e" } },
    { "id": "deny-reverse-shell-ncat-e",  "verdict": "deny", "match": { "argv_pattern": "ncat -e" } }
  ]
}
